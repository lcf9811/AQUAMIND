            {
              "name": "optimize_dosing",
              "description": "碳源投加量优化 (C/N, VFA/TP)",
              "parameters": [],
              "returns": "dosing_result"
            },
            {
              "name": "optimize_mixing",
              "description": "搅拌强度优化 (3~8 W/m³, DO<0.2)",
              "parameters": [],
              "returns": "mixing_result"
            },
            {
              "name": "optimize_recirculation",
              "description": "污泥回流比优化 (浓度法)",
              "parameters": [],
              "returns": "recirculation_result"
            }
          ],
